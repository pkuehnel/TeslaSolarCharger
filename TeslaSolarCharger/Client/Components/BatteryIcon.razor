@if (StateOfCharge != default)
{
    <svg width="42" height="21" viewBox="0 0 42 21">
        <rect x="1" y="1" width="38" height="19" rx="2" ry="2"
              style="fill:var(--bs-body-bg); stroke:currentColor; stroke-width:1.4" />
        <rect x="39" y="6" width="3" height="9"
              style="fill:currentColor; stroke:currentColor; stroke-width:0.7" />
        <rect x="2" y="2" width="@(36 * StateOfCharge / 100)" height="17"
              style="fill:@GetBatteryColor(StateOfCharge.Value); stroke-width:0" />
        <text x="21" y="12" text-anchor="middle" fill="currentColor"
              style="font-size: 10px; font-weight: bold; dominant-baseline: middle;">
            @StateOfCharge%
        </text>
    </svg>
}

@using TeslaSolarCharger.Client.Services.Contracts

@inject IAppColors AppColors
@inject IThemeStateService ThemeStateService
@implements IDisposable

@code {
    [Parameter]
    public int? StateOfCharge { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        ThemeStateService.OnDarkModeChanged += OnDarkModeChangedHandler;
    }

    private async Task OnDarkModeChangedHandler(bool isDarkMode)
    {
        await InvokeAsync(() =>
        {
            StateHasChanged();
        });
    }

    private string GetBatteryColor(int soc)
    {
        if (soc > 50) return AppColors.BatterySocGoodColor;
        if (soc > 25) return AppColors.BatterySocWarningColor;
        return AppColors.BatterySocCriticalColor;
    }

    public void Dispose()
    {
        ThemeStateService.OnDarkModeChanged -= OnDarkModeChangedHandler;
    }
}