@using TeslaSolarCharger.Client.Services.Contracts
@using TeslaSolarCharger.Shared.Localization
@using TeslaSolarCharger.Shared.Localization.Contracts
@using TeslaSolarCharger.Shared.Localization.Registries
@using TeslaSolarCharger.Shared.Localization.Registries.Pages

@implements IDisposable
@inject ISignalRStateService SignalRStateService
@inject ITextLocalizationService TextLocalizer
@inject ILogger<SignalRConnectionStateComponent> Logger

@if (!SignalRStateService.IsConnected)
{
    <div class="my-2">
        <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Left" Class="d-flex align-center" NoIcon="true">
            <div class="d-flex align-center">
                <div class="mr-3">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                </div>
                
                <div>
                    <MudText Typo="Typo.body1">@T(TranslationKeys.SignalRReconnecting)</MudText>
                    @if (_showDelayHint)
                    {
                        <MudText Typo="Typo.body2" Class="mt-1">@T(TranslationKeys.SignalRReconnectionDelayHint)</MudText>
                    }
                </div>
            </div>
        </MudAlert>
    </div>
}

@code {
    private const int HintDelayMilliseconds = 5000;

    private CancellationTokenSource? _delayCts;
    private bool _showDelayHint;

    protected override void OnInitialized()
    {
        SignalRStateService.OnConnectionStateChanged += HandleConnectionStateChanged;
        UpdateHintTimer();
    }

    private void HandleConnectionStateChanged()
    {
        UpdateHintTimer();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateHintTimer()
    {
        if (_delayCts != null)
        {
            _delayCts.Cancel();
            _delayCts.Dispose();
            _delayCts = null;
        }

        _showDelayHint = false;

        if (!SignalRStateService.IsConnected)
        {
            _delayCts = new CancellationTokenSource();
            var token = _delayCts.Token; // Capture the token locally
        
            _ = ShowHintAfterDelay(token);
        }
    }

    private async Task ShowHintAfterDelay(CancellationToken token)
    {
        try
        {
            await Task.Delay(HintDelayMilliseconds, token);
        
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(() => 
                {
                    _showDelayHint = true;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { /* Normal */ }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ShowHintAfterDelay");
        }

    }

    private string T(string key) =>
        TextLocalizer.Get<HomePageLocalizationRegistry>(key, typeof(SharedComponentLocalizationRegistry))
        ?? key;

    public void Dispose()
    {
        SignalRStateService.OnConnectionStateChanged -= HandleConnectionStateChanged;
        _delayCts?.Cancel();
        _delayCts?.Dispose();
    }
}
