@inherits LayoutComponentBase
@using TeslaSolarCharger.Shared.Localization
@using TeslaSolarCharger.Shared.Localization.Contracts
@using TeslaSolarCharger.Shared.Localization.Registries
@using TeslaSolarCharger.Client.Services.Contracts

@inject IAppColors AppColors
@inject ITextLocalizationService TextLocalizer
@inject IJSRuntime JsRuntime
@inject IThemeStateService ThemeStateService

<MudThemeProvider @ref="@_mudThemeProvider" Theme="_tscTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.Medium" />
<MudSnackbarProvider />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @T(TranslationKeys.MainLayoutUnhandledError)
    <a href="." class="reload">@T(TranslationKeys.MainLayoutReload)</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private string T(string key) =>
        TextLocalizer.Get<SharedComponentLocalizationRegistry>(key)
        ?? key;

    private MudThemeProvider? _mudThemeProvider;

    private MudTheme? _tscTheme;

    private bool _wasMudThemeProviderNull;
    private bool _isDarkMode;

    protected override void OnInitialized()
    {
        _tscTheme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary = AppColors.PrimaryColor,
                Secondary = AppColors.SecondaryColor,
                AppbarBackground = AppColors.PrimaryColor, // or a const you define
            },
            PaletteDark = new PaletteDark
            {
                Primary = AppColors.PrimaryColor,
                Secondary = AppColors.SecondaryColor,
                AppbarBackground = AppColors.PrimaryColor, // or a const you define
                Background = AppColors.DarkModeBackgroundColor,
                BackgroundGray = AppColors.DarkModeBackgroundColor,
                Surface = AppColors.DarkModeBackgroundColor,
            },
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _wasMudThemeProviderNull)
        {
            if (_mudThemeProvider == default)
            {
                _wasMudThemeProviderNull = true;
            }
            else
            {
                _wasMudThemeProviderNull = false;
                _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
                await ThemeStateService.SetDarkModeAsync(_isDarkMode);
                await SyncBootstrapThemeAsync(_isDarkMode);
                await InvokeAsync(async () =>
                {
                    await _mudThemeProvider.WatchSystemDarkModeAsync(OnSystemDarkModeChanged);
                    StateHasChanged();
                }); 
            }

        }
    }

    private async Task OnSystemDarkModeChanged(bool newValue)
    {
        _isDarkMode = newValue;
        await ThemeStateService.SetDarkModeAsync(newValue);
        await SyncBootstrapThemeAsync(newValue);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncBootstrapThemeAsync(bool isDarkMode)
    {
        var theme = isDarkMode ? "dark" : "light";
        await JsRuntime.InvokeVoidAsync("setBootstrapTheme", theme);
    }
}
